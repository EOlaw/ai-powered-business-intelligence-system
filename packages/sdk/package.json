{
  "name": "@insightserenity/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript/JavaScript SDK for the InsightSerenity AI platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.1.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "insightserenity",
    "ai",
    "llm",
    "sdk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
