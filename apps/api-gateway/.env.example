# InsightSerenity API Gateway — Environment Variables
# Copy this file to .env and fill in all values before starting.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://insightserenity:password@localhost:5432/insightserenity_gateway"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET="CHANGE_ME_AT_LEAST_48_CHARS_LONG_access_secret_here"
JWT_REFRESH_SECRET="CHANGE_ME_AT_LEAST_48_CHARS_LONG_refresh_secret_here"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── AI Engine (internal service) ──────────────────────────────────────────────
AI_ENGINE_URL="http://localhost:8001"
# Must match SERVING_INTERNAL_API_SECRET in the Python AI engine
SERVING_INTERNAL_API_SECRET="change-me-in-production"

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
API_KEY_BYTES=24

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins, or * for development
CORS_ORIGINS="http://localhost:3001,http://localhost:5173"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
LOG_PRETTY=true
