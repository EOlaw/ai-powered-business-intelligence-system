{
  "name": "@insightserenity/worker",
  "version": "1.0.0",
  "description": "InsightSerenity data flywheel worker — crawl → clean → train → hot-swap",
  "main": "dist/main.js",
  "scripts": {
    "build":    "tsc -p tsconfig.json",
    "start":    "node dist/main.js",
    "dev":      "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bullmq":    "^5.12.2",
    "ioredis":   "^5.4.1",
    "pino":      "^9.3.2",
    "node-cron": "^4.2.1",
    "zod":       "^3.23.8"
  },
  "devDependencies": {
    "@types/node":      "^22.1.0",
    "tsx":              "^4.16.2",
    "typescript":       "^5.5.4"
  },
  "engines": { "node": ">=20.0.0" }
}
